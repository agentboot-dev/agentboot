{
  "name": "agentboot",
  "version": "0.2.0",
  "description": "Convention over configuration for agentic development teams. The Spring Boot of Claude Code governance.",
  "license": "Apache-2.0",
  "author": "Mike Saavedra <mike@agentboot.dev>",
  "homepage": "https://agentboot.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentboot-dev/agentboot.git"
  },
  "bugs": {
    "url": "https://github.com/agentboot-dev/agentboot/issues"
  },
  "keywords": [
    "claude-code",
    "copilot",
    "ai-agents",
    "agentskills",
    "developer-tools",
    "governance",
    "convention-over-configuration",
    "personas",
    "traits",
    "agent-governance",
    "llm",
    "claude",
    "anthropic",
    "code-review",
    "security-review",
    "test-generation"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "bin": {
    "agentboot": "./bin/agentboot.js"
  },
  "scripts": {
    "cli": "tsx scripts/cli.ts",
    "clean": "rm -rf dist/",
    "dev-sync": "tsx scripts/dev-sync.ts",
    "build": "tsx scripts/compile.ts",
    "validate": "tsx scripts/validate.ts",
    "sync": "tsx scripts/sync.ts",
    "dev-build": "npm run clean && npm run validate && npm run build && npm run dev-sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'No lint errors'"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "tsx": "^4.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
